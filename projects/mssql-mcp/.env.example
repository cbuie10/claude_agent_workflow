# SQL Server connection settings
# Copy this file to .env and fill in your values

# Server host (IP or hostname)
MSSQL_HOST=localhost

# Server port
MSSQL_PORT=1433

# Database name (REQUIRED)
MSSQL_DATABASE=your_database

# SQL Authentication credentials (not needed if using Windows auth)
MSSQL_USER=your_username
MSSQL_PASSWORD=your_password

# ODBC driver name (must be installed on your system)
MSSQL_DRIVER=ODBC Driver 17 for SQL Server

# Set to true to use Windows/AD authentication instead of SQL auth
MSSQL_WINDOWS_AUTH=false

# Safety: only allow SELECT queries (set to false to enable writes)
MSSQL_READ_ONLY=true

# Query timeout in seconds
MSSQL_QUERY_TIMEOUT=30

# Maximum rows returned per query
MSSQL_MAX_ROWS=10000
